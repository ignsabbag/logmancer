{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Logmancer",
  "version": "0.2.0",
  "identifier": "com.ignsabbag.logmancer",
  "build": {
    "beforeDevCommand": "cargo leptos watch --project logmancer-web",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cargo leptos build --release --project logmancer-web",
    "frontendDist": "../target/site"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Logmancer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
